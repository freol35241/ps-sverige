---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "How does the Swedish parliament actually vote and reason? A data-driven analysis of the 2022–2026 mandate.",
  image = "01_behavioural_map.png",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = "https://freol35241.github.io";
const ogImage = `${siteOrigin}${base}/figures/${image}`;
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/method`, label: 'Method' },
  { href: `${base}/about`, label: 'About' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Riksdag Revealed" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="site-title" href={`${base}/`}>
          <span class="site-mark">rr</span>
          <span>Riksdag Revealed</span>
        </a>
        <nav>
          <ul>
            {navLinks.map(link => {
              const isCurrent = currentPath === link.href.replace(/\/$/, '');
              return (
                <li>
                  <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>{link.label}</a>
                </li>
              );
            })}
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>
          Source data: Sveriges riksdag, open data. Code: <a href="https://github.com/freol35241/ps-sverige">github.com/freol35241/ps-sverige</a>.
        </p>
        <p class="footer-disclaimer">
          This is not an official tool. It is an analysis of public voting and document data from the Swedish parliament, mandate 2022/23–2025/26.
        </p>
      </div>
    </footer>

    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Zoomed figure" hidden>
      <button id="lightbox-close" class="lightbox-close" aria-label="Close">&times;</button>
      <img id="lightbox-image" src="" alt="" />
    </div>

    <script is:inline>
      (function () {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-image');
        const closeBtn = document.getElementById('lightbox-close');
        if (!lightbox || !lightboxImg || !closeBtn) return;

        function open(src, alt) {
          lightboxImg.src = src;
          lightboxImg.alt = alt || '';
          lightbox.hidden = false;
          document.body.style.overflow = 'hidden';
        }
        function close() {
          lightbox.hidden = true;
          lightboxImg.src = '';
          document.body.style.overflow = '';
        }

        document.querySelectorAll('figure img').forEach(function (img) {
          img.classList.add('zoomable');
          img.setAttribute('tabindex', '0');
          img.setAttribute('role', 'button');
          img.setAttribute('aria-label', 'Zoom figure');
          img.addEventListener('click', function () {
            open(img.currentSrc || img.src, img.alt);
          });
          img.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              open(img.currentSrc || img.src, img.alt);
            }
          });
        });

        lightbox.addEventListener('click', function (e) {
          if (e.target === lightbox || e.target === lightboxImg) close();
        });
        closeBtn.addEventListener('click', close);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && !lightbox.hidden) close();
        });
      })();
    </script>
  </body>
</html>
